{
  "name": "otak-clipboard",
  "displayName": "otak-clipboard",
  "description": "%extension.description%",
  "publisher": "odangoo",
  "license": "MIT",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsuyoshi-otake/otak-clipboard"
  },
  "bugs": {
    "url": "https://github.com/tsuyoshi-otake/otak-clipboard/issues"
  },
  "homepage": "https://github.com/tsuyoshi-otake/otak-clipboard#readme",
  "version": "1.1.2",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "type": "object",
      "title": "otak-clipboard",
      "properties": {
        "otakClipboard.useGitignore": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.useGitignore%"
        },
        "otakClipboard.maxCharacters": {
          "type": "number",
          "default": 400000,
          "markdownDescription": "%config.maxCharacters%"
        },
        "otakClipboard.maxFiles": {
          "type": "number",
          "default": 400,
          "markdownDescription": "%config.maxFiles%"
        },
        "otakClipboard.excludeDirectories": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            ".git",
            "node_modules",
            "out"
          ],
          "markdownDescription": "%config.excludeDirectories%"
        },
        "otakClipboard.knownTextExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "txt",
            "md",
            "markdown",
            "json",
            "yaml",
            "yml",
            "toml",
            "js",
            "ts",
            "jsx",
            "tsx",
            "py",
            "rb",
            "php",
            "java",
            "css",
            "scss",
            "less",
            "html",
            "htm",
            "xml",
            "sh",
            "bash",
            "zsh",
            "ini",
            "conf",
            "cfg",
            "log",
            "csv",
            "tsv",
            "gitignore",
            "env"
          ],
          "markdownDescription": "%config.knownTextExtensions%"
        },
        "otakClipboard.knownBinaryExtensions": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "exe",
            "dll",
            "so",
            "dylib",
            "bin",
            "obj"
          ],
          "markdownDescription": "%config.knownBinaryExtensions%"
        },
        "otakClipboard.binaryDetectionRules": {
          "type": "object",
          "default": {
            "nullByteCheck": true,
            "controlCharRatio": 0.3,
            "controlCharCheck": true
          },
          "markdownDescription": "%config.binaryDetectionRules%"
        },
        "otakClipboard.detectSensitiveData": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.detectSensitiveData%"
        },
        "otakClipboard.sensitiveDataPatterns": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": {
                "type": "string"
              },
              "pattern": {
                "type": "string"
              },
              "confidence": {
                "type": "string",
                "enum": [
                  "high",
                  "medium",
                  "low"
                ]
              }
            }
          },
          "default": [],
          "markdownDescription": "%config.sensitiveDataPatterns%"
        },
        "otakClipboard.maskShowPartial": {
          "type": "boolean",
          "default": true,
          "markdownDescription": "%config.maskShowPartial%"
        }
      }
    },
    "commands": [
      {
        "command": "otakClipboard.copyCurrentTab",
        "title": "%command.copyCurrentTab%"
      },
      {
        "command": "otakClipboard.copyAllOpenedTabs",
        "title": "%command.copyAllOpenedTabs%"
      },
      {
        "command": "otakClipboard.copyFile",
        "title": "%command.copyFile%"
      },
      {
        "command": "otakClipboard.copyFolder",
        "title": "%command.copyFolder%"
      },
      {
        "command": "otakClipboard.copyFolderRecursive",
        "title": "%command.copyFolderRecursive%"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "otakClipboard.copyFile",
          "when": "!explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "otakClipboard.copyFolder",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        },
        {
          "command": "otakClipboard.copyFolderRecursive",
          "when": "explorerResourceIsFolder",
          "group": "navigation"
        }
      ],
      "editor/title/context": [
        {
          "command": "otakClipboard.copyCurrentTab",
          "group": "navigation"
        },
        {
          "command": "otakClipboard.copyAllOpenedTabs",
          "group": "navigation"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "gen:nls": "node scripts/gen-package-nls.mjs",
    "compile": "npm run gen:nls && tsc -p ./ && node -e \"require('fs').cpSync('src/i18n/locales', 'out/i18n/locales', {recursive: true})\"",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "20.x",
    "@types/vscode": "1.90.0",
    "@typescript-eslint/eslint-plugin": "^8.22.0",
    "@typescript-eslint/parser": "^8.22.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.6.0",
    "eslint": "^9.26.1",
    "typescript": "^5.7.3"
  },
  "dependencies": {
    "ignore": "^5.3.2"
  },
  "overrides": {
    "brace-expansion@1": "1.1.13",
    "brace-expansion@2": "2.0.3",
    "diff": "8.0.3",
    "serialize-javascript": "7.0.5"
  }
}
